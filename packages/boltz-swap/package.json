{
    "name": "@arkade-os/boltz-swap",
    "version": "0.3.0-next.0",
    "type": "module",
    "description": "A production-ready TypeScript package that brings Boltz submarine-swaps to Arkade.",
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "import": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.js"
            },
            "require": {
                "types": "./dist/index.d.ts",
                "default": "./dist/index.cjs"
            }
        },
        "./expo": {
            "import": {
                "types": "./dist/expo/index.d.ts",
                "default": "./dist/expo/index.js"
            },
            "require": {
                "types": "./dist/expo/index.d.ts",
                "default": "./dist/expo/index.cjs"
            }
        },
        "./adapters/sqlite": {
            "import": {
                "types": "./dist/adapters/sqlite.d.ts",
                "default": "./dist/adapters/sqlite.js"
            },
            "require": {
                "types": "./dist/adapters/sqlite.d.ts",
                "default": "./dist/adapters/sqlite.cjs"
            }
        },
        "./adapters/realm": {
            "import": {
                "types": "./dist/adapters/realm.d.ts",
                "default": "./dist/adapters/realm.js"
            },
            "require": {
                "types": "./dist/adapters/realm.d.ts",
                "default": "./dist/adapters/realm.cjs"
            }
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/expo/index.ts src/adapters/sqlite.ts src/adapters/realm.ts --format esm,cjs --dts --clean",
        "format": "prettier --write src test",
        "lint": "prettier --check src test",
        "prepack": "pnpm run build",
        "test": "vitest run",
        "test:unit": "vitest run --exclude test/e2e",
        "test:setup": "test/setupRegtestEnv.sh",
        "test:integration": "vitest run test/e2e/**",
        "test:down": "test/setupRegtestEnv.sh down",
        "test:build-docker": "docker compose -f test.docker-compose.yml build --no-cache",
        "test:up-docker": "docker compose -f test.docker-compose.yml up arkd arkd-wallet nbxplorer pgnbxplorer -d",
        "test:setup-docker": "node test/e2e/setup.mjs",
        "test:integration-docker": "vitest run test/e2e/**",
        "test:down-docker": "docker compose -f test.docker-compose.yml down -v",
        "release": "pnpm run build && bash scripts/release.sh",
        "release:dry-run": "bash scripts/release.sh --dry-run",
        "release:cleanup": "bash scripts/release.sh --cleanup",
        "regtest": "pnpm -C ../.. regtest:test"
    },
    "keywords": [
        "arkade",
        "boltz",
        "swap",
        "lightning",
        "bitcoin"
    ],
    "author": "Arkade-OS",
    "license": "MIT",
    "dependencies": {
        "@arkade-os/sdk": "workspace:*",
        "@noble/hashes": "2.0.1",
        "@scure/base": "2.0.0",
        "@scure/btc-signer": "2.0.1",
        "bip68": "^1.0.4",
        "@noble/curves": "^2.0.1",
        "light-bolt11-decoder": "3.2.0"
    },
    "devDependencies": {
        "@eslint/js": "^9.35.0",
        "@types/node": "^24.3.1",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.43.0",
        "@typescript-eslint/parser": "^8.43.0",
        "eslint": "^9.35.0",
        "eventsource": "^4.1.0",
        "fake-indexeddb": "^6.0.0",
        "prettier": "3.6.2",
        "tsup": "^8.5.0",
        "typescript": "^5.9.2",
        "vite": "7.1.11",
        "vitest": "^3.2.4"
    },
    "engines": {
        "node": ">=22.12.0 <23",
        "pnpm": ">=10.25.0 <11"
    },
    "publishConfig": {
        "access": "public"
    },
    "packageManager": "pnpm@10.25.0"
}
